# ATLAS MCP Agent — Environment Configuration
# Copy this to .env and fill in your values.
#
# ── LLM Backend ──────────────────────────────────────────
# Options: "gemini", "openai", or "llama"
LLM_BACKEND=gemini

# ── Gemini API (when LLM_BACKEND=gemini) ─────────────────
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemini-2.0-flash
# Other models: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-lite

# ── OpenAI-compatible API (when LLM_BACKEND=openai) ─────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Local Llama (when LLM_BACKEND=llama) ─────────────────
# LLAMA_MODEL_PATH=./models/model.gguf

# ── Agent Settings ───────────────────────────────────────
# PLAYWRIGHT_HEADLESS=false
# DEBUG=false
# DEBUG=false
