# ATLAS MCP Agent — Environment Configuration
# Copy this to .env and fill in your values.
#
# ── LLM Backend ──────────────────────────────────────────
# Options: "openai" or "llama"
LLM_BACKEND=openai

# ── OpenAI-compatible API (when LLM_BACKEND=openai) ─────
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o-mini
# For other providers, set the base URL:
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_BASE_URL=http://localhost:11434/v1  # Ollama
# OPENAI_BASE_URL=https://api.together.xyz/v1

# ── Local Llama (when LLM_BACKEND=llama) ─────────────────
# LLAMA_MODEL_PATH=./models/model.gguf

# ── Agent Settings ───────────────────────────────────────
# PLAYWRIGHT_HEADLESS=false
# DEBUG=false
