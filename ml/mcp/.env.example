# ATLAS MCP Agent — Environment Configuration
# Copy this to .env and fill in your values.
#
# ── LLM Backend ──────────────────────────────────────────
# Options: "openai" (OpenRouter/OpenAI), "gemini" (direct), or "llama"

# ── RECOMMENDED: OpenRouter (free credits, many models) ──
# Sign up: https://openrouter.ai  |  Keys: https://openrouter.ai/keys
LLM_BACKEND=openai
OPENAI_API_KEY=your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=google/gemini-2.0-flash-exp:free
# Free models:  google/gemini-2.0-flash-exp:free
#               meta-llama/llama-4-maverick:free
#               deepseek/deepseek-chat-v3-0324:free

# ── Gemini direct (needs GCP billing enabled) ────────────
# LLM_BACKEND=gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI direct ────────────────────────────────────────
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Local Llama (offline) ────────────────────────────────
# LLM_BACKEND=llama
# LLAMA_MODEL_PATH=./models/model.gguf
# ── Chrome Profile ───────────────────────────────────────────
# Use your real Chrome browser with all cookies/sessions.
# IMPORTANT: Close Chrome fully (including system tray) before running!
CHROME_PROFILE=true
# CHROME_USER_DATA_DIR=C:\Users\<you>\AppData\Local\Google\Chrome\User Data
# For a specific profile, append the folder: ...\User Data\Profile 4
# Set CHROME_PROFILE=false to use a clean Playwright Chromium instead.
# ── Agent Settings ───────────────────────────────────────
# PLAYWRIGHT_HEADLESS=false
# DEBUG=false
